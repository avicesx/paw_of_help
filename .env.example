# Скопируйте в `.env` в корне репозитория и подставьте свои значения.

# Async SQLAlchemy + asyncpg (обязательно драйвер asyncpg в URL)
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@localhost:5432/paw_of_help

# Секрет для подписи JWT (длинная случайная строка)
JWT_SECRET_KEY=replace-with-a-long-random-secret

# Алгоритм JWT (по умолчанию HS256)
ALGORITHM=HS256

# Срок жизни access token в минутах
ACCESS_TOKEN_EXPIRE_MINUTES=30

# true — печатать SQL в консоль (только для отладки)
DATABASE_ECHO=false

# CORS: через запятую, например http://localhost:5173,http://127.0.0.1:3000
# Пусто или * — любой origin (без credentials; для локальной разработки)
CORS_ORIGINS=

# Лимит запросов к POST /auth/login и /auth/register (slowapi, на IP)
AUTH_RATE_LIMIT=10/minute
