# Скопируйте в `.env`
#
# docker compose up — backend в контейнере, хосты сервисов: db, redis, ollama.
# Локальный backend на хосте (инфра в Docker) — замените хосты на localhost (см. блок внизу).

# --- PostgreSQL (сервис db) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=paw_of_help

# Секрет для подписи JWT — замените на длинную случайную строку
JWT_SECRET_KEY=replace-with-a-long-random-secret

# Алгоритм JWT (по умолчанию HS256)
ALGORITHM=HS256

# Срок жизни access token в минутах
ACCESS_TOKEN_EXPIRE_MINUTES=30

# true — печатать SQL в консоль (только для отладки)
DATABASE_ECHO=false

# Live Server (порт 5500) или фронт из compose (8080) — перечислите все origin через запятую
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://localhost:5500,http://127.0.0.1:5500
AUTH_RATE_LIMIT=10/minute

# Backend в Docker: хост redis
REDIS_URL=redis://redis:6379/0

# Время жизни кэша ленты в секундах
FEED_CACHE_TTL=300

# Веса алгоритма ранжирования
WEIGHT_URGENCY=50.0
WEIGHT_DISTANCE=20.0
WEIGHT_SKILL=15.0
WEIGHT_FOSTER=15.0
WEIGHT_TIME=10.0

# Опционально HF_TOKEN — быстрее загрузка моделей: https://huggingface.co/settings/tokens
# HF_TOKEN=
CONTENT_MODEL_BASE=weeqeen/rubert-base-cased-finetuned-moderation
CONTENT_MODEL_TINY=weeqeen/rubert-tiny2-moderation

# Параметры модели
CONTENT_THRESHOLD=0.65
CONTENT_BASE_WEIGHT=0.3
CONTENT_TINY_WEIGHT=0.7

# Загрузка изображений (volume paw_uploads в docker compose)
UPLOAD_DIR=/app/uploads
PUBLIC_BASE_URL=http://localhost:8000
UPLOAD_MAX_SIZE_MB=10

OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_TAG_MODEL=gemma2:9b
OLLAMA_TIMEOUT_SECONDS=600

# --- Локальный backend на хосте (только инфра в Docker) ---
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/paw_of_help
# REDIS_URL=redis://localhost:6379/0
# OLLAMA_BASE_URL=http://localhost:11434