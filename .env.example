# Скопируйте в `.env` в корне репозитория и подставьте свои значения.

# Async SQLAlchemy + asyncpg (обязательно драйвер asyncpg в URL)
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@localhost:5432/paw_of_help

# Секрет для подписи JWT (длинная случайная строка)
JWT_SECRET_KEY=replace-with-a-long-random-secret

# Алгоритм JWT (по умолчанию HS256)
ALGORITHM=HS256

# Срок жизни access token в минутах
ACCESS_TOKEN_EXPIRE_MINUTES=30

# true — печатать SQL в консоль (только для отладки)
DATABASE_ECHO=false

# CORS: через запятую, например http://localhost:5173,http://127.0.0.1:3000
# Пусто или * — любой origin (без credentials; для локальной разработки)
CORS_ORIGINS=

# Лимит запросов к POST /auth/login и /auth/register (slowapi, на IP)
AUTH_RATE_LIMIT=10/minute

# URL для подключения к Redis
REDIS_URL=redis://localhost:6379/0

# Время жизни кэша ленты в секундах
FEED_CACHE_TTL=300

# Веса алгоритма ранжирования
WEIGHT_URGENCY=50.0
WEIGHT_DISTANCE=20.0
WEIGHT_SKILL=15.0
WEIGHT_FOSTER=15.0
WEIGHT_TIME=10.0

# Идентификаторы Hugging Face Hub для ContentModerationAgent.
# Скачиваются при первом запуске backend в volume huggingface_hub (не при docker build).
# Опционально HF_TOKEN — быстрее и стабильнее: https://huggingface.co/settings/tokens
# HF_TOKEN=
CONTENT_MODEL_BASE=weeqeen/rubert-base-cased-finetuned-moderation
CONTENT_MODEL_TINY=weeqeen/rubert-tiny2-moderation

# Параметры модели
CONTENT_THRESHOLD=0.65
CONTENT_BASE_WEIGHT=0.3
CONTENT_TINY_WEIGHT=0.7

# Загрузка изображений (volume paw_uploads в docker compose)
UPLOAD_DIR=/app/uploads
PUBLIC_BASE_URL=http://localhost:8000
UPLOAD_MAX_SIZE_MB=10

# Ollama — теги статей/постов (gemma2:9b), при docker compose up модель кэшируется в volume ollama_data
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_TAG_MODEL=gemma2:9b
OLLAMA_TIMEOUT_SECONDS=120